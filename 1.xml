<Module>
    <ModulePrefs title="Among Us Online" />
    <Content type="html">
        <![CDATA[
        <!DOCTYPE html>
        <html lang="en">
        <head>
            <base href="https://cdn.jsdelivr.net/gh/jsonsonson/Ysys@main/">
            <meta charset="utf-8">
            <title>Among Us Online</title>
            <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
            <style>
                html,body{margin:0;padding:0;width:100%;height:100%;overflow:hidden;background:#231F20;}
                .webgl-content{width:100%;height:100%;}
            </style>
        </head>
        <body>
            <div class="webgl-content">
                <div id="unityContainer" style="width:100%;height:100%;"></div>
            </div>
            
            <script src="Build/UnityLoader.js"></script>
            <script src="Build/UnityProgress.js"></script>
            
            <script>
                // Instanciação segura após o carregamento da DOM
                window.addEventListener('load', function() {
                    var unityInstance = UnityLoader.instantiate("unityContainer", "Build/AmongUs2019_WebGL.json", {
                        onProgress: function(gameInstance, progress) {
                            if (typeof UnityProgress === 'function') {
                                UnityProgress(gameInstance, progress);
                            }
                        }
                    });
                });
            </script>
        </body>
        </html>
        ]]>
    </Content>
</Module>
